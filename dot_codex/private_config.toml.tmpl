model = "gpt-5.5"
model_reasoning_effort = "medium"
personality = "pragmatic"
service_tier = "fast"
approval_policy = "never"
sandbox_mode = "danger-full-access"

notify = ["{{ .chezmoi.homeDir }}/.codex/computer-use/Codex Computer Use.app/Contents/SharedSupport/SkyComputerUseClient.app/Contents/MacOS/SkyComputerUseClient", "turn-ended"]

[features]
codex_hooks = true
collaboration_modes = true
multi_agent = true
goals = true

[mcp_servers.pencil]
command = "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64"
args = [ "--app", "desktop" ]

[projects."{{ .chezmoi.homeDir }}/conductor/repos"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/ghq"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/.local/share/chezmoi"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/conductor/repos/ow-management-v1"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/conductor/repos/changer-all"]
trust_level = "trusted"

[plugins."github@openai-curated"]
enabled = true

[plugins."computer-use@openai-bundled"]
enabled = true

[plugins."documents@openai-primary-runtime"]
enabled = true

[plugins."spreadsheets@openai-primary-runtime"]
enabled = true

[plugins."presentations@openai-primary-runtime"]
enabled = true

[plugins."slack@openai-curated"]
enabled = true

[plugins."google-calendar@openai-curated"]
enabled = true

[plugins."gmail@openai-curated"]
enabled = true

[plugins."browser@openai-bundled"]
enabled = true

[plugins."chrome@openai-bundled"]
enabled = true
