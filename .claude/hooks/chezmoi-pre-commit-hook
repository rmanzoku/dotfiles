#!/bin/bash
set -eu

# Claude Code の PreToolUse hook から呼ばれるスクリプト
# chezmoi ソースと実機の差分がある場合にコミットをブロックする

# Bash ツールの呼び出し情報は stdin JSON で渡される。git commit 以外は何もしない。
payload="$(cat)"
tool_command="$(printf '%s' "$payload" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("tool_input", {}).get("command", ""))')"

case "$tool_command" in
  git\ commit* ) ;;
  * ) exit 0 ;;
esac

# chezmoi が利用可能か確認
if ! command -v chezmoi >/dev/null 2>&1; then
  exit 0
fi

if ! scripts/chezmoi-drift --check-ignore >/dev/null 2>&1; then
  echo "chezmoi の source state と .chezmoiignore の不整合を検出しました。"
  echo ""
  echo "確認方法:"
  echo "  scripts/chezmoi-drift --check-ignore"
  echo ""
  echo ".chezmoiignore を修正してからコミットしてください。"
  exit 2
fi

# chezmoi diff を実行
diff_output="$(chezmoi diff 2>/dev/null || true)"

if [ -z "$diff_output" ]; then
  exit 0
fi

# 差分ファイル一覧を抽出（最大20行）
files="$(echo "$diff_output" | grep -E '^(---|\+\+\+) [ab]/' | sed 's|^... [ab]/|  |' | sort -u | head -20)"

echo "chezmoi ドリフトを検出しました。コミット前に解消してください。"
echo ""
echo "差分のあるファイル:"
echo "$files"
echo ""
echo "解消方法:"
echo "  scripts/chezmoi-drift --apply   (外部の変更を取り込む)"
echo "  scripts/chezmoi-drift --restore (chezmoi ソースの状態に戻す)"

exit 2
