#!/bin/bash
set -eu

usage() {
  cat <<'EOF'
Usage: chezmoi-drift [--apply | --restore]

chezmoi 管理下のファイルが外部で変更された場合を検出・対応します。

オプション:
  (なし)      差分のあるファイルを一覧表示
  --apply     外部の変更を chezmoi ソースに取り込む (chezmoi re-add)
  --restore   chezmoi ソースの状態に戻す (chezmoi apply)
  --help      このヘルプを表示
EOF
}

info() { printf '\033[1;34m[info]\033[0m %s\n' "$1"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$1"; }

check_drift() {
  local diff_output
  diff_output="$(chezmoi diff 2>/dev/null || true)"
  if [ -z "$diff_output" ]; then
    info "差分はありません。すべてのファイルが chezmoi ソースと一致しています。"
    return 1
  fi
  # diff 出力からファイルパスを抽出 (--- a/path or +++ b/path)
  echo "$diff_output" | grep -E '^(---|\+\+\+) [ab]/' | sed 's|^... [ab]/|/|' | sort -u
  return 0
}

confirm() {
  printf '\033[1;33m%s [y/N]: \033[0m' "$1"
  read -r answer
  case "$answer" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

case "${1:-}" in
  --help|-h)
    usage
    ;;
  "")
    info "chezmoi 管理下のファイルの差分を確認しています..."
    if check_drift; then
      echo ""
      info "上記のファイルに差分があります。"
      info "変更を取り込むには: chezmoi-drift --apply"
      info "管理状態に戻すには: chezmoi-drift --restore"
    fi
    ;;
  --apply)
    info "外部の変更を chezmoi ソースに取り込みます..."
    if ! check_drift; then
      exit 0
    fi
    echo ""
    if confirm "上記のファイルの変更を chezmoi ソースに取り込みますか？"; then
      chezmoi re-add
      info "変更を取り込みました。"
    else
      info "キャンセルしました。"
    fi
    ;;
  --restore)
    info "chezmoi ソースの状態に復元します..."
    if ! check_drift; then
      exit 0
    fi
    echo ""
    if confirm "上記のファイルを chezmoi ソースの状態に戻しますか？"; then
      chezmoi apply --force
      info "復元しました。"
    else
      info "キャンセルしました。"
    fi
    ;;
  *)
    echo "不明なオプション: $1" >&2
    usage >&2
    exit 1
    ;;
esac
