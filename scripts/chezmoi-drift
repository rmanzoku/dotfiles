#!/bin/bash
set -eu

exec 3<&0

usage() {
  cat <<'EOF'
Usage: chezmoi-drift [--apply | --restore | --check-ignore]

リポジトリの dot_* ファイルと実ファイルの差分を検出・対応します。

オプション:
  (なし)      差分のあるファイルを一覧表示
  --apply     実ファイルの変更をリポジトリに取り込む (chezmoi re-add)
  --restore   リポジトリの状態に実ファイルを戻す (chezmoi apply)
  --check-ignore  source と .chezmoiignore の矛盾を検査
  --help      このヘルプを表示
EOF
}

info() { printf '\033[1;34m[info]\033[0m %s\n' "$1"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$1"; }
error() { printf '\033[1;31m[error]\033[0m %s\n' "$1" >&2; }

# chezmoi ignore されている dot_* ファイルの直接比較対象
# dot_ プレフィックスを . に変換したパスと対応
EXTRA_FILES=(
  "dot_claude/CLAUDE.md:.claude/CLAUDE.md:raw"
  "dot_claude/settings.json:.claude/settings.json:raw"
  "dot_codex/private_config.toml:.codex/config.toml:raw"
)

EXPECTED_IGNORED_SOURCES=(
  "Brewfile"
  "CLAUDE.md"
  "README.md"
  "scripts"
  "setup.sh"
)

is_expected_ignored_source() {
  local source_rel="$1"
  local expected
  for expected in "${EXPECTED_IGNORED_SOURCES[@]}"; do
    if [ "$source_rel" = "$expected" ]; then
      return 0
    fi
  done
  return 1
}

check_ignore_consistency() {
  local repo_root="$1"
  local ignored_output source_rel target_path has_issue=false

  ignored_output="$(chezmoi ignored --source-path -S "$repo_root" 2>/dev/null || true)"

  while IFS= read -r source_rel; do
    [ -n "$source_rel" ] || continue
    if is_expected_ignored_source "$source_rel"; then
      continue
    fi

    target_path="$(chezmoi target-path -S "$repo_root" "$repo_root/$source_rel" 2>/dev/null || true)"
    if [ -n "$target_path" ]; then
      error "source が .chezmoiignore により無効化されています: $source_rel -> $target_path"
    else
      error "source が .chezmoiignore により無効化されています: $source_rel"
    fi
    has_issue=true
  done <<EOF
$ignored_output
EOF

  if $has_issue; then
    error ".chezmoiignore を確認し、意図せず無効化した source を解消してから続行してください。"
    return 1
  fi

  return 0
}

render_template_to_file() {
  local repo_file="$1"
  local output_file="$2"
  chezmoi execute-template <"$repo_file" >"$output_file"
}

files_differ() {
  local repo_file="$1"
  local actual_file="$2"
  local mode="$3"

  case "$mode" in
    raw)
      ! cmp -s "$repo_file" "$actual_file"
      ;;
    template)
      local rendered_file
      rendered_file="$(mktemp)"
      render_template_to_file "$repo_file" "$rendered_file"
      if cmp -s "$rendered_file" "$actual_file"; then
        rm -f "$rendered_file"
        return 1
      fi
      rm -f "$rendered_file"
      return 0
      ;;
    *)
      warn "未知の比較モードです: $mode"
      return 1
      ;;
  esac
}

copy_actual_to_repo() {
  local repo_file="$1"
  local actual_file="$2"
  local mode="$3"

  case "$mode" in
    raw)
      cp "$actual_file" "$repo_file"
      ;;
    template)
      perl -0pe 's/\Q$ENV{HOME}\E/\{\{ .chezmoi.homeDir \}\}/g' "$actual_file" >"$repo_file"
      ;;
  esac
}

copy_repo_to_actual() {
  local repo_file="$1"
  local actual_file="$2"
  local mode="$3"

  case "$mode" in
    raw)
      cp "$repo_file" "$actual_file"
      ;;
    template)
      render_template_to_file "$repo_file" "$actual_file"
      ;;
  esac
}

check_extra_drift() {
  local repo_root="$1"
  local has_drift=false
  for entry in "${EXTRA_FILES[@]}"; do
    IFS=':' read -r repo_rel actual_rel mode <<<"$entry"
    local repo_file="${repo_root}/${repo_rel}"
    local actual_file="${HOME}/${actual_rel}"
    if [ -f "$repo_file" ] && [ -f "$actual_file" ]; then
      if files_differ "$repo_file" "$actual_file" "$mode"; then
        echo "/${actual_rel}"
        has_drift=true
      fi
    elif [ -f "$repo_file" ] && [ ! -f "$actual_file" ]; then
      echo "/${actual_rel} (missing)"
      has_drift=true
    fi
  done
  $has_drift
}

check_drift() {
  local repo_root diff_output has_drift=false
  repo_root="$(git rev-parse --show-toplevel)"

  if ! check_ignore_consistency "$repo_root"; then
    has_drift=true
  fi

  # chezmoi 管理対象
  diff_output="$(chezmoi diff -S "$repo_root" 2>/dev/null || true)"
  if [ -n "$diff_output" ]; then
    echo "$diff_output" | grep -E '^(---|\+\+\+) [ab]/' | sed 's|^... [ab]/|/|' | sort -u
    has_drift=true
  fi

  # chezmoi ignore 対象（直接比較）
  if check_extra_drift "$repo_root"; then
    has_drift=true
  fi

  if ! $has_drift; then
    info "差分はありません。すべてのファイルがリポジトリと一致しています。"
    return 1
  fi
  return 0
}

confirm() {
  printf '\033[1;33m%s [y/N]: \033[0m' "$1"
  read -r answer <&3
  case "$answer" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

case "${1:-}" in
  --help|-h)
    usage
    ;;
  "")
    info "リポジトリと実ファイルの差分を確認しています..."
    if check_drift; then
      echo ""
      info "上記のファイルに差分があります。"
      info "変更を取り込むには: chezmoi-drift --apply"
      info "管理状態に戻すには: chezmoi-drift --restore"
    fi
    ;;
  --check-ignore)
    info ".chezmoiignore と source state の整合を確認しています..."
    repo_root="$(git rev-parse --show-toplevel)"
    if check_ignore_consistency "$repo_root"; then
      info "問題はありません。source state と .chezmoiignore は整合しています。"
      exit 0
    fi
    exit 1
    ;;
  --apply)
    info "実ファイルの変更をリポジトリに取り込みます..."
    repo_root="$(git rev-parse --show-toplevel)"
    if ! check_ignore_consistency "$repo_root"; then
      exit 1
    fi
    if ! check_drift; then
      exit 0
    fi
    echo ""
    if confirm "上記のファイルの変更をリポジトリに取り込みますか？"; then
      chezmoi re-add -S "$repo_root"
      # chezmoi ignore 対象は直接コピー
      for entry in "${EXTRA_FILES[@]}"; do
        IFS=':' read -r repo_rel actual_rel mode <<<"$entry"
        repo_file="${repo_root}/${repo_rel}"
        actual_file="${HOME}/${actual_rel}"
        if [ -f "$actual_file" ] && [ -f "$repo_file" ]; then
          if files_differ "$repo_file" "$actual_file" "$mode"; then
            copy_actual_to_repo "$repo_file" "$actual_file" "$mode"
          fi
        fi
      done
      info "変更を取り込みました。"
    else
      info "キャンセルしました。"
    fi
    ;;
  --restore)
    info "リポジトリの状態に復元します..."
    repo_root="$(git rev-parse --show-toplevel)"
    if ! check_ignore_consistency "$repo_root"; then
      exit 1
    fi
    if ! check_drift; then
      exit 0
    fi
    echo ""
    if confirm "上記のファイルをリポジトリの状態に戻しますか？"; then
      chezmoi apply --force -S "$repo_root"
      # chezmoi ignore 対象は直接コピー
      for entry in "${EXTRA_FILES[@]}"; do
        IFS=':' read -r repo_rel actual_rel mode <<<"$entry"
        repo_file="${repo_root}/${repo_rel}"
        actual_file="${HOME}/${actual_rel}"
        if [ -f "$repo_file" ]; then
          if [ ! -f "$actual_file" ] || files_differ "$repo_file" "$actual_file" "$mode"; then
            copy_repo_to_actual "$repo_file" "$actual_file" "$mode"
          fi
        fi
      done
      info "復元しました。"
    else
      info "キャンセルしました。"
    fi
    ;;
  *)
    echo "不明なオプション: $1" >&2
    usage >&2
    exit 1
    ;;
esac
