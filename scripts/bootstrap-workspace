#!/usr/bin/env bash
set -euo pipefail

REPO_URL="${WORKSPACE_REPO_URL:-https://github.com/rmanzoku/workspace.git}"
REPO_HOST_PATH="${WORKSPACE_REPO_HOST_PATH:-github.com/rmanzoku/workspace}"

info() { printf '\033[1;34m[info]\033[0m %s\n' "$1"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$1"; }
fail() {
  printf 'bootstrap-workspace: %s\n' "$*" >&2
  exit 1
}

resolve_root() {
  if command -v ghq >/dev/null 2>&1; then
    local root
    root="$(ghq root 2>/dev/null | sed -n '1p' || true)"
    if [[ -n "$root" ]]; then
      printf '%s\n' "$root"
      return 0
    fi
    warn "ghq is installed but ghq root is unavailable; falling back to ~/workspace"
  fi

  printf '%s\n' "${WORKSPACE_ROOT:-$HOME/workspace}"
}

ensure_remote_matches() {
  local target="$1"
  local actual
  actual="$(git -C "$target" remote get-url origin 2>/dev/null || true)"
  if [[ -z "$actual" ]]; then
    fail "existing repository has no origin remote: $target"
  fi
  case "$actual" in
    "$REPO_URL"|git@github.com:rmanzoku/workspace.git|https://github.com/rmanzoku/workspace)
      ;;
    *)
      fail "existing repository origin is unexpected: $actual"
      ;;
  esac
}

pull_existing() {
  local target="$1"
  ensure_remote_matches "$target"
  info "Updating workspace: $target"
  git -C "$target" pull --ff-only
}

clone_repo() {
  local target="$1"
  mkdir -p "$(dirname "$target")"
  info "Cloning workspace into: $target"
  git clone "$REPO_URL" "$target"
}

main() {
  command -v git >/dev/null 2>&1 || fail "git is required"

  local root target
  root="$(resolve_root)"
  target="${WORKSPACE_TARGET:-$root/$REPO_HOST_PATH}"

  if [[ -d "$target/.git" ]]; then
    pull_existing "$target"
  elif [[ -e "$target" ]]; then
    fail "target exists but is not a git repository: $target"
  else
    clone_repo "$target"
  fi

  printf '%s\n' "$target"
}

main "$@"
