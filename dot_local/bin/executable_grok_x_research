#!/usr/bin/env python3
"""Run a bounded Grok X-research request from a file artifact."""

from __future__ import annotations

import argparse
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any
from urllib import error, request


DEFAULT_BASE_URL = "https://api.x.ai/v1"
DEFAULT_MODEL = "grok-4.20-reasoning"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Delegate X-focused research to Grok using file-based request and response artifacts."
    )
    parser.add_argument("--request", required=True, help="Path to the JSON request artifact.")
    parser.add_argument("--response", required=True, help="Path to write the JSON response artifact.")
    parser.add_argument(
        "--model",
        default=os.getenv("GROK_X_RESEARCH_MODEL", DEFAULT_MODEL),
        help="xAI model name. Defaults to GROK_X_RESEARCH_MODEL or grok-4.20-reasoning.",
    )
    parser.add_argument(
        "--base-url",
        default=os.getenv("XAI_BASE_URL", DEFAULT_BASE_URL),
        help="xAI API base URL. Defaults to XAI_BASE_URL or https://api.x.ai/v1.",
    )
    parser.add_argument(
        "--timeout",
        type=int,
        default=300,
        help="HTTP timeout in seconds. Defaults to 300.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Validate input and print the outbound payload without calling the API.",
    )
    return parser.parse_args()


def load_json(path: Path) -> dict[str, Any]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError as exc:
        raise SystemExit(f"request artifact not found: {path}") from exc
    except json.JSONDecodeError as exc:
        raise SystemExit(f"request artifact is not valid JSON: {path}: {exc}") from exc


def require_string(data: dict[str, Any], key: str) -> str:
    value = data.get(key)
    if not isinstance(value, str) or not value.strip():
        raise SystemExit(f"request artifact must include non-empty string '{key}'")
    return value.strip()


def normalize_string_list(value: Any, *, field: str) -> list[str]:
    if value is None:
        return []
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise SystemExit(f"'{field}' must be an array of strings")
    return [item.strip() for item in value if item.strip()]


def validate_iso_date(value: str, *, field: str) -> str:
    try:
        datetime.strptime(value, "%Y-%m-%d")
    except ValueError as exc:
        raise SystemExit(f"'{field}' must use YYYY-MM-DD format") from exc
    return value


def build_tool_config(data: dict[str, Any]) -> dict[str, Any]:
    config = data.get("x_search") or {}
    if not isinstance(config, dict):
        raise SystemExit("'x_search' must be an object when provided")

    allowed = normalize_string_list(config.get("allowed_x_handles"), field="x_search.allowed_x_handles")
    excluded = normalize_string_list(config.get("excluded_x_handles"), field="x_search.excluded_x_handles")
    if allowed and excluded:
        raise SystemExit("x_search.allowed_x_handles and x_search.excluded_x_handles cannot be used together")
    if len(allowed) > 10 or len(excluded) > 10:
        raise SystemExit("x_search handle lists cannot exceed 10 entries")

    tool: dict[str, Any] = {"type": "x_search"}
    if allowed:
        tool["allowed_x_handles"] = allowed
    if excluded:
        tool["excluded_x_handles"] = excluded

    for key in ("from_date", "to_date"):
        value = config.get(key)
        if value is not None:
            if not isinstance(value, str):
                raise SystemExit(f"x_search.{key} must be a string")
            tool[key] = validate_iso_date(value, field=f"x_search.{key}")

    for key in ("enable_image_understanding", "enable_video_understanding"):
        value = config.get(key)
        if value is not None:
            if not isinstance(value, bool):
                raise SystemExit(f"x_search.{key} must be a boolean")
            tool[key] = value

    return tool


def build_user_prompt(data: dict[str, Any]) -> str:
    question = require_string(data, "question")
    lines = [f"Task ID: {require_string(data, 'task')}", f"Question: {question}"]

    language = data.get("language")
    if isinstance(language, str) and language.strip():
        lines.append(f"Output language: {language.strip()}")

    audience = data.get("audience")
    if isinstance(audience, str) and audience.strip():
        lines.append(f"Audience: {audience.strip()}")

    context_items = data.get("context")
    if isinstance(context_items, list):
        cleaned = [item.strip() for item in context_items if isinstance(item, str) and item.strip()]
        if cleaned:
            lines.append("Context:")
            lines.extend(f"- {item}" for item in cleaned)
    elif isinstance(context_items, str) and context_items.strip():
        lines.append(f"Context: {context_items.strip()}")

    constraints = normalize_string_list(data.get("constraints"), field="constraints")
    if constraints:
        lines.append("Constraints:")
        lines.extend(f"- {item}" for item in constraints)

    deliverable = data.get("deliverable")
    if isinstance(deliverable, dict):
        sections = normalize_string_list(deliverable.get("sections"), field="deliverable.sections")
        if sections:
            lines.append("Required sections:")
            lines.extend(f"- {item}" for item in sections)
        max_posts = deliverable.get("max_draft_posts")
        if isinstance(max_posts, int):
            lines.append(f"Maximum draft posts: {max_posts}")

    lines.append("Support every substantive claim with concrete X-native or linked sources when available.")
    lines.append("Keep speculation clearly labeled and include it in risks when it affects interpretation.")
    return "\n".join(lines)


def response_schema() -> dict[str, Any]:
    source_schema = {
        "type": "object",
        "properties": {
            "title": {"type": "string"},
            "url": {"type": "string"},
            "note": {"type": "string"},
        },
        "required": ["title", "url", "note"],
        "additionalProperties": False,
    }
    return {
        "type": "json_schema",
        "name": "grok_x_research_result",
        "strict": True,
        "schema": {
            "type": "object",
            "properties": {
                "summary": {"type": "string"},
                "angles": {"type": "array", "items": {"type": "string"}},
                "draft_posts": {"type": "array", "items": {"type": "string"}},
                "risks": {"type": "array", "items": {"type": "string"}},
                "sources": {"type": "array", "items": source_schema},
            },
            "required": ["summary", "angles", "draft_posts", "risks", "sources"],
            "additionalProperties": False,
        },
    }


def build_payload(data: dict[str, Any], *, model: str) -> dict[str, Any]:
    tool = build_tool_config(data)
    return {
        "model": model,
        "input": [
            {
                "role": "system",
                "content": (
                    "You are Grok operating as a specialized X researcher. "
                    "Use X Search to gather recent, concrete evidence and return only structured JSON."
                ),
            },
            {
                "role": "user",
                "content": build_user_prompt(data),
            },
        ],
        "tools": [tool],
        "text": {"format": response_schema()},
    }


def api_key() -> str:
    value = os.getenv("XAI_API_KEY")
    if not value:
        raise SystemExit("XAI_API_KEY is required. Premium+ access does not provide API access for this script.")
    return value


def post_json(url: str, payload: dict[str, Any], *, timeout: int) -> dict[str, Any]:
    encoded = json.dumps(payload).encode("utf-8")
    req = request.Request(
        url,
        data=encoded,
        headers={
            "Authorization": f"Bearer {api_key()}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with request.urlopen(req, timeout=timeout) as response:
            return json.loads(response.read().decode("utf-8"))
    except error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace")
        raise SystemExit(f"xAI API request failed with HTTP {exc.code}: {detail}") from exc
    except error.URLError as exc:
        raise SystemExit(f"xAI API request failed: {exc}") from exc


def extract_output_text(response: dict[str, Any]) -> str:
    output_text = response.get("output_text")
    if isinstance(output_text, str) and output_text.strip():
        return output_text

    for item in response.get("output", []):
        if item.get("type") != "message":
            continue
        for content in item.get("content", []):
            if content.get("type") == "output_text":
                text = content.get("text")
                if isinstance(text, str) and text.strip():
                    return text
    raise SystemExit("xAI response did not include output text")


def extract_citations(response: dict[str, Any]) -> list[dict[str, str]]:
    citations: list[dict[str, str]] = []
    seen: set[tuple[str, str, str]] = set()
    for item in response.get("output", []):
        if item.get("type") != "message":
            continue
        for content in item.get("content", []):
            if content.get("type") != "output_text":
                continue
            for annotation in content.get("annotations", []):
                url = annotation.get("url") or annotation.get("source_url") or ""
                title = annotation.get("title") or annotation.get("display_title") or url or "citation"
                note = annotation.get("type") or "annotation"
                if not url:
                    continue
                key = (title, url, note)
                if key in seen:
                    continue
                seen.add(key)
                citations.append({"title": title, "url": url, "note": note})
    return citations


def build_response_artifact(parsed: dict[str, Any], response: dict[str, Any], *, model: str) -> dict[str, Any]:
    artifact = dict(parsed)
    artifact["raw_model"] = {
        "response_id": response.get("id"),
        "model": response.get("model", model),
        "created_at": datetime.now(timezone.utc).isoformat(),
        "usage": response.get("usage"),
        "citations": extract_citations(response),
    }
    if not artifact.get("sources") and artifact["raw_model"]["citations"]:
        artifact["sources"] = artifact["raw_model"]["citations"]
    return artifact


def write_json(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def main() -> int:
    args = parse_args()
    request_path = Path(args.request)
    response_path = Path(args.response)
    request_data = load_json(request_path)
    payload = build_payload(request_data, model=args.model)

    if args.dry_run:
        print(json.dumps(payload, ensure_ascii=False, indent=2))
        return 0

    response = post_json(f"{args.base_url.rstrip('/')}/responses", payload, timeout=args.timeout)
    output_text = extract_output_text(response)
    try:
        parsed = json.loads(output_text)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"xAI structured output was not valid JSON: {exc}\nRaw output:\n{output_text}") from exc

    artifact = build_response_artifact(parsed, response, model=args.model)
    write_json(response_path, artifact)
    print(str(response_path))
    return 0


if __name__ == "__main__":
    sys.exit(main())
