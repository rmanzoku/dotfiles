#!/bin/sh
set -eu

for candidate in \
  "$HOME/.codex/skills/onepassword-secret-materialize/scripts/opmaterialize" \
  "$HOME/.claude/skills/onepassword-secret-materialize/scripts/opmaterialize" \
  "$HOME/.local/share/chezmoi/skills/onepassword-secret-materialize/scripts/opmaterialize"
do
  if [ -f "$candidate" ]; then
    exec sh "$candidate" "$@"
  fi
done

printf '%s\n' "opmaterialize: onepassword-secret-materialize skill script not found" >&2
printf '%s\n' "install it with: gh skill install <dotfiles-repo> onepassword-secret-materialize --from-local --agent codex --scope user" >&2
exit 127
